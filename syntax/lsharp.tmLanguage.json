{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "L#",
  "scopeName": "source.lsharp",
  "fileTypes": ["ls", "lsharp"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#ui-keywords" },
    { "include": "#module-keywords" },
    { "include": "#state-keywords" },
    { "include": "#lifecycle-keywords" },
    { "include": "#event-keywords" },
    { "include": "#style-keywords" },
    { "include": "#layout-keywords" },
    { "include": "#animation-keywords" },
    { "include": "#jsx-tags" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.lsharp",
          "match": "//.*$"
        },
        {
          "name": "comment.block.lsharp",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.lsharp",
          "match": "\\b(if|else|elif|match|case|for|while|loop|break|continue|return|yield|await|async)\\b"
        },
        {
          "name": "keyword.other.lsharp",
          "match": "\\b(let|const|var|fn|func|function|class|struct|enum|interface|trait|impl|type|alias)\\b"
        },
        {
          "name": "storage.modifier.lsharp",
          "match": "\\b(pub|priv|protected|static|final|abstract|virtual|override|mut|ref|unsafe|extern|dyn|macro|derive)\\b"
        },
        {
          "name": "keyword.operator.new.lsharp",
          "match": "\\b(new|delete|sizeof|typeof|instanceof|as|in|is)\\b"
        }
      ]
    },
    "module-keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.lsharp",
          "match": "\\b(import|export|deport|report)\\b"
        },
        {
          "name": "keyword.control.from.lsharp",
          "match": "\\b(from|direct|use|as)\\b"
        }
      ]
    },
    "ui-keywords": {
      "patterns": [
        {
          "name": "storage.type.component.lsharp",
          "match": "\\b(component|render|props)\\b"
        },
        {
          "name": "entity.name.tag.component.lsharp",
          "match": "\\b(Container|Card|Button|Input|Text|Image|Icon|Canvas|GLCanvas|Grid|Stack|Box|Modal|Tooltip|TextArea|Checkbox|Radio|Switch|Slider|Dropdown)\\b"
        }
      ]
    },
    "state-keywords": {
      "patterns": [
        {
          "name": "support.function.hook.lsharp",
          "match": "\\b(useState|useEffect|useContext|useRef|useMemo|useCallback|useReducer|useLayoutEffect|useImperativeHandle|useDebugValue)\\b"
        },
        {
          "name": "keyword.other.state.lsharp",
          "match": "\\b(state|computed)\\b"
        }
      ]
    },
    "lifecycle-keywords": {
      "patterns": [
        {
          "name": "support.function.lifecycle.lsharp",
          "match": "\\b(onMount|onUnmount|onUpdate|beforeRender|afterRender|shouldUpdate|onError)\\b"
        }
      ]
    },
    "event-keywords": {
      "patterns": [
        {
          "name": "support.function.event.lsharp",
          "match": "\\b(onClick|onChange|onSubmit|onInput|onFocus|onBlur|onKeyDown|onKeyUp|onKeyPress|onMouseDown|onMouseUp|onMouseMove|onMouseEnter|onMouseLeave|onMouseOver|onMouseOut|onWheel|onScroll|onDrag|onDragStart|onDragEnd|onDragEnter|onDragLeave|onDragOver|onDrop|onTouchStart|onTouchMove|onTouchEnd|onTouchCancel)\\b"
        }
      ]
    },
    "style-keywords": {
      "patterns": [
        {
          "name": "support.type.property-name.css.lsharp",
          "match": "\\b(style|className|width|height|margin|padding|border|borderRadius|background|backgroundColor|color|fontSize|fontWeight|fontFamily|display|position|top|right|bottom|left|zIndex|opacity|transform|transition|animation|boxShadow|textShadow|overflow|cursor)\\b"
        },
        {
          "name": "support.function.gradient.lsharp",
          "match": "\\b(linearGradient|radialGradient|conicGradient)\\b"
        },
        {
          "name": "support.function.transform.lsharp",
          "match": "\\b(translate|translateX|translateY|scale|scaleX|scaleY|rotate|rotateX|rotateY|skew|skewX|skewY|matrix|perspective)\\b"
        },
        {
          "name": "support.function.filter.lsharp",
          "match": "\\b(blur|brightness|contrast|grayscale|hueRotate|invert|saturate|sepia|dropShadow)\\b"
        }
      ]
    },
    "layout-keywords": {
      "patterns": [
        {
          "name": "support.type.layout.lsharp",
          "match": "\\b(layout|flex|grid|stack|absolute|relative|fixed|sticky)\\b"
        },
        {
          "name": "support.type.property-name.flexbox.lsharp",
          "match": "\\b(flexDirection|flexWrap|flexGrow|flexShrink|flexBasis|alignItems|alignContent|alignSelf|justifyContent|justifyItems|justifySelf)\\b"
        },
        {
          "name": "support.type.property-name.grid.lsharp",
          "match": "\\b(gridTemplateColumns|gridTemplateRows|gridTemplateAreas|gridColumn|gridRow|gridArea|gridGap|gridColumnGap|gridRowGap|gridAutoFlow|gridAutoColumns|gridAutoRows)\\b"
        },
        {
          "name": "support.constant.layout-value.lsharp",
          "match": "\\b(row|column|wrap|nowrap|center|start|end|stretch|baseline|space-between|space-around|space-evenly)\\b"
        }
      ]
    },
    "animation-keywords": {
      "patterns": [
        {
          "name": "support.type.animation.lsharp",
          "match": "\\b(animation|keyframes|transition)\\b"
        },
        {
          "name": "support.constant.timing-function.lsharp",
          "match": "\\b(ease|ease-in|ease-out|ease-in-out|linear|step-start|step-end)\\b"
        },
        {
          "name": "support.constant.animation-value.lsharp",
          "match": "\\b(infinite|normal|reverse|alternate|alternate-reverse|forwards|backwards|both|running|paused)\\b"
        }
      ]
    },
    "jsx-tags": {
      "patterns": [
        {
          "name": "meta.tag.jsx.lsharp",
          "begin": "(<)([A-Z][a-zA-Z0-9]*)",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx.lsharp" },
            "2": { "name": "entity.name.tag.jsx.lsharp" }
          },
          "end": "(/>)|(>)",
          "endCaptures": {
            "1": { "name": "punctuation.definition.tag.self-closing.jsx.lsharp" },
            "2": { "name": "punctuation.definition.tag.end.jsx.lsharp" }
          },
          "patterns": [
            { "include": "#jsx-attributes" }
          ]
        },
        {
          "name": "meta.tag.jsx.closing.lsharp",
          "match": "(</)([A-Z][a-zA-Z0-9]*)(>)",
          "captures": {
            "1": { "name": "punctuation.definition.tag.begin.jsx.lsharp" },
            "2": { "name": "entity.name.tag.jsx.lsharp" },
            "3": { "name": "punctuation.definition.tag.end.jsx.lsharp" }
          }
        }
      ]
    },
    "jsx-attributes": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.jsx.lsharp",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_-]*(?=\\s*=)"
        },
        {
          "name": "meta.embedded.expression.jsx.lsharp",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lsharp",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.lsharp",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.lsharp",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.lsharp",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.template.lsharp",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "meta.embedded.expression.lsharp",
              "begin": "\\$\\{",
              "end": "\\}",
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.lsharp",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.lsharp",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.octal.lsharp",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "name": "constant.numeric.float.lsharp",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.lsharp",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.lsharp",
          "match": "\\+|\\-|\\*|\\/|%|\\*\\*"
        },
        {
          "name": "keyword.operator.comparison.lsharp",
          "match": "==|!=|<|>|<=|>=|===|!=="
        },
        {
          "name": "keyword.operator.logical.lsharp",
          "match": "&&|\\|\\||!|\\?\\?|\\?\\."
        },
        {
          "name": "keyword.operator.bitwise.lsharp",
          "match": "&|\\||\\^|~|<<|>>"
        },
        {
          "name": "keyword.operator.assignment.lsharp",
          "match": "=|\\+=|\\-=|\\*=|\\/=|%=|&=|\\|=|\\^=|<<=|>>="
        },
        {
          "name": "keyword.operator.arrow.lsharp",
          "match": "=>|->|::"
        },
        {
          "name": "keyword.operator.spread.lsharp",
          "match": "\\.\\.\\."
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.lsharp",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.lsharp",
          "match": "\\b(printf|scanf|malloc|free|memcpy|strlen|strcmp|glBegin|glEnd|glVertex3f|glColor3f)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.lsharp",
          "match": "\\b(int|float|double|bool|string|char|byte|void|any|never)\\b"
        },
        {
          "name": "entity.name.type.lsharp",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.lsharp",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.lsharp",
          "match": "\\b(null|nil|undefined)\\b"
        },
        {
          "name": "constant.language.lsharp",
          "match": "\\b(this|self|super|base)\\b"
        }
      ]
    }
  }
}
