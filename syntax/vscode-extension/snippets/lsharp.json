{
  "Component": {
    "prefix": "comp",
    "body": [
      "component ${1:ComponentName} {",
      "  render {",
      "    <Container>",
      "      $0",
      "    </Container>",
      "  }",
      "}"
    ],
    "description": "Create a new L# component"
  },
  "Component with State": {
    "prefix": "compstate",
    "body": [
      "component ${1:ComponentName} {",
      "  const [${2:value}, set${2/(.*)/${1:/capitalize}/}] = useState(${3:initialValue});",
      "  ",
      "  render {",
      "    <Container>",
      "      $0",
      "    </Container>",
      "  }",
      "}"
    ],
    "description": "Create component with useState"
  },
  "useState": {
    "prefix": "ust",
    "body": [
      "const [${1:value}, set${1/(.*)/${1:/capitalize}/}] = useState(${2:initialValue});"
    ],
    "description": "useState hook"
  },
  "useEffect": {
    "prefix": "uef",
    "body": [
      "useEffect(() => {",
      "  $0",
      "}, [${1:dependencies}]);"
    ],
    "description": "useEffect hook"
  },
  "useRef": {
    "prefix": "urf",
    "body": [
      "const ${1:ref} = useRef(${2:null});"
    ],
    "description": "useRef hook"
  },
  "useMemo": {
    "prefix": "umm",
    "body": [
      "const ${1:memoized} = useMemo(() => {",
      "  return $0",
      "}, [${2:dependencies}]);"
    ],
    "description": "useMemo hook"
  },
  "useCallback": {
    "prefix": "ucb",
    "body": [
      "const ${1:callback} = useCallback(() => {",
      "  $0",
      "}, [${2:dependencies}]);"
    ],
    "description": "useCallback hook"
  },
  "Import from Cloud": {
    "prefix": "impf",
    "body": [
      "import ${1:name} from { ${2:library} }"
    ],
    "description": "Import from cloud library"
  },
  "Import Direct": {
    "prefix": "impd",
    "body": [
      "import ${1:name}, direct '${2:./path}'"
    ],
    "description": "Import from native/local file"
  },
  "Export Component": {
    "prefix": "expc",
    "body": [
      "export component ${1:ComponentName} {",
      "  render {",
      "    $0",
      "  }",
      "}"
    ],
    "description": "Export a component"
  },
  "Export Function": {
    "prefix": "expf",
    "body": [
      "export function ${1:functionName}(${2:params}) {",
      "  $0",
      "}"
    ],
    "description": "Export a function"
  },
  "Container": {
    "prefix": "cont",
    "body": [
      "<Container style={{",
      "  ${1:display}: \"${2:flex}\",",
      "  ${3:alignItems}: \"${4:center}\"",
      "}}>",
      "  $0",
      "</Container>"
    ],
    "description": "Container component"
  },
  "Card": {
    "prefix": "card",
    "body": [
      "<Card style={{",
      "  padding: \"${1:24px}\",",
      "  borderRadius: \"${2:16px}\",",
      "  boxShadow: \"${3:0 4px 12px rgba(0,0,0,0.1)}\"",
      "}}>",
      "  $0",
      "</Card>"
    ],
    "description": "Card component"
  },
  "Button": {
    "prefix": "btn",
    "body": [
      "<Button ",
      "  onClick={${1:handleClick}}",
      "  style={{",
      "    padding: \"${2:12px 24px}\",",
      "    background: \"${3:#667eea}\",",
      "    color: \"${4:#ffffff}\",",
      "    borderRadius: \"${5:8px}\"",
      "  }}",
      ">",
      "  ${6:Button Text}",
      "</Button>"
    ],
    "description": "Button component"
  },
  "Input": {
    "prefix": "inp",
    "body": [
      "<Input ",
      "  value={${1:value}}",
      "  onChange={(e) => set${1/(.*)/${1:/capitalize}/}(e.target.value)}",
      "  placeholder=\"${2:Enter text...}\"",
      "  style={{",
      "    padding: \"${3:12px}\",",
      "    borderRadius: \"${4:8px}\"",
      "  }}",
      "/>"
    ],
    "description": "Input component"
  },
  "Text": {
    "prefix": "txt",
    "body": [
      "<Text style={{",
      "  fontSize: \"${1:16px}\",",
      "  fontWeight: \"${2:normal}\",",
      "  color: \"${3:#333}\"",
      "}}>",
      "  ${4:Text content}",
      "</Text>"
    ],
    "description": "Text component"
  },
  "Linear Gradient": {
    "prefix": "lgrad",
    "body": [
      "background: \"linear-gradient(${1:135deg}, ${2:#667eea} ${3:0%}, ${4:#764ba2} ${5:100%})\""
    ],
    "description": "Linear gradient"
  },
  "Flexbox Layout": {
    "prefix": "flex",
    "body": [
      "display: \"flex\",",
      "flexDirection: \"${1:row}\",",
      "alignItems: \"${2:center}\",",
      "justifyContent: \"${3:center}\",",
      "gap: \"${4:16px}\""
    ],
    "description": "Flexbox layout properties"
  },
  "Grid Layout": {
    "prefix": "grid",
    "body": [
      "display: \"grid\",",
      "gridTemplateColumns: \"${1:repeat(3, 1fr)}\",",
      "gap: \"${2:16px}\""
    ],
    "description": "Grid layout properties"
  },
  "Animation": {
    "prefix": "anim",
    "body": [
      "animation ${1:name} {",
      "  from {",
      "    ${2:opacity}: ${3:0};",
      "  }",
      "  to {",
      "    ${2:opacity}: ${4:1};",
      "  }",
      "}"
    ],
    "description": "Animation definition"
  },
  "Transition": {
    "prefix": "trans",
    "body": [
      "transition: \"${1:all} ${2:0.3s} ${3:ease}\""
    ],
    "description": "Transition property"
  },
  "Box Shadow": {
    "prefix": "bshad",
    "body": [
      "boxShadow: \"${1:0} ${2:4px} ${3:12px} rgba(${4:0,0,0,0.1})\""
    ],
    "description": "Box shadow"
  },
  "Event Handler": {
    "prefix": "evh",
    "body": [
      "function handle${1:Event}(${2:e}) {",
      "  $0",
      "}"
    ],
    "description": "Event handler function"
  },
  "Lifecycle onMount": {
    "prefix": "lmnt",
    "body": [
      "onMount {",
      "  $0",
      "}"
    ],
    "description": "onMount lifecycle method"
  },
  "Lifecycle onUnmount": {
    "prefix": "lumnt",
    "body": [
      "onUnmount {",
      "  $0",
      "}"
    ],
    "description": "onUnmount lifecycle method"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for (let ${1:i} = 0; ${1:i} < ${2:length}; ${1:i}++) {",
      "  $0",
      "}"
    ],
    "description": "For loop"
  },
  "If Statement": {
    "prefix": "if",
    "body": [
      "if (${1:condition}) {",
      "  $0",
      "}"
    ],
    "description": "If statement"
  },
  "Function": {
    "prefix": "fn",
    "body": [
      "function ${1:functionName}(${2:params}) {",
      "  $0",
      "}"
    ],
    "description": "Function declaration"
  },
  "Arrow Function": {
    "prefix": "af",
    "body": [
      "const ${1:functionName} = (${2:params}) => {",
      "  $0",
      "}"
    ],
    "description": "Arrow function"
  },
  "Console Log": {
    "prefix": "log",
    "body": [
      "printf(\"${1:message}: %s\\n\", ${2:value});"
    ],
    "description": "Print to console"
  },
  "Try Catch": {
    "prefix": "try",
    "body": [
      "try {",
      "  $0",
      "} catch (${1:error}) {",
      "  printf(\"Error: %s\\n\", ${1:error});",
      "}"
    ],
    "description": "Try catch block"
  },
  "Theme": {
    "prefix": "theme",
    "body": [
      "theme ${1:themeName} {",
      "  colors: {",
      "    primary: \"${2:#667eea}\",",
      "    secondary: \"${3:#764ba2}\",",
      "    background: \"${4:#ffffff}\",",
      "    text: \"${5:#333333}\"",
      "  },",
      "  spacing: {",
      "    small: \"${6:8px}\",",
      "    medium: \"${7:16px}\",",
      "    large: \"${8:24px}\"",
      "  }",
      "}"
    ],
    "description": "Theme definition"
  },
  "Media Query": {
    "prefix": "media",
    "body": [
      "@media (${1:min-width}: ${2:768px}) {",
      "  $0",
      "}"
    ],
    "description": "Media query"
  },
  "Responsive Value": {
    "prefix": "resp",
    "body": [
      "${1:property}: {",
      "  mobile: \"${2:value1}\",",
      "  tablet: \"${3:value2}\",",
      "  desktop: \"${4:value3}\"",
      "}"
    ],
    "description": "Responsive value"
  }
}
