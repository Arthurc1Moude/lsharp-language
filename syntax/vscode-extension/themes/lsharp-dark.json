{
  "name": "L# Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#1e1e2e",
    "editor.foreground": "#cdd6f4",
    "editorCursor.foreground": "#f5e0dc",
    "editor.lineHighlightBackground": "#313244",
    "editorLineNumber.foreground": "#6c7086",
    "editorLineNumber.activeForeground": "#f5e0dc",
    "editor.selectionBackground": "#45475a",
    "editor.inactiveSelectionBackground": "#313244",
    "editorIndentGuide.background": "#313244",
    "editorIndentGuide.activeBackground": "#45475a",
    "editorWhitespace.foreground": "#45475a",
    "editorBracketMatch.background": "#45475a",
    "editorBracketMatch.border": "#89b4fa",
    "sideBar.background": "#181825",
    "sideBar.foreground": "#cdd6f4",
    "sideBarSectionHeader.background": "#1e1e2e",
    "activityBar.background": "#181825",
    "activityBar.foreground": "#cdd6f4",
    "statusBar.background": "#181825",
    "statusBar.foreground": "#cdd6f4",
    "titleBar.activeBackground": "#181825",
    "titleBar.activeForeground": "#cdd6f4",
    "panel.background": "#1e1e2e",
    "terminal.background": "#1e1e2e",
    "terminal.foreground": "#cdd6f4"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6c7086",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword.control", "keyword.other", "storage.modifier"],
      "settings": {
        "foreground": "#cba6f7",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["keyword.control.import", "keyword.control.from"],
      "settings": {
        "foreground": "#f38ba8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["storage.type.component", "entity.name.tag.component"],
      "settings": {
        "foreground": "#89dceb",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["support.function.hook", "support.function.lifecycle"],
      "settings": {
        "foreground": "#f9e2af",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.function.event"],
      "settings": {
        "foreground": "#fab387",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["support.type.property-name.css", "support.type.property-name.flexbox", "support.type.property-name.grid"],
      "settings": {
        "foreground": "#94e2d5"
      }
    },
    {
      "scope": ["support.function.gradient", "support.function.transform", "support.function.filter"],
      "settings": {
        "foreground": "#a6e3a1"
      }
    },
    {
      "scope": ["support.type.layout", "support.type.animation"],
      "settings": {
        "foreground": "#89b4fa"
      }
    },
    {
      "scope": ["entity.name.tag.jsx", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#89dceb"
      }
    },
    {
      "scope": ["entity.other.attribute-name.jsx"],
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "scope": ["string.quoted", "string.template"],
      "settings": {
        "foreground": "#a6e3a1"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#fab387"
      }
    },
    {
      "scope": ["constant.language.boolean", "constant.language.null"],
      "settings": {
        "foreground": "#f38ba8"
      }
    },
    {
      "scope": ["entity.name.function", "support.function.builtin"],
      "settings": {
        "foreground": "#89b4fa"
      }
    },
    {
      "scope": ["storage.type.primitive", "entity.name.type"],
      "settings": {
        "foreground": "#f9e2af"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#94e2d5"
      }
    },
    {
      "scope": ["variable.parameter"],
      "settings": {
        "foreground": "#cdd6f4"
      }
    },
    {
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#bac2de"
      }
    },
    {
      "scope": ["meta.embedded.expression"],
      "settings": {
        "foreground": "#f5c2e7"
      }
    }
  ]
}
